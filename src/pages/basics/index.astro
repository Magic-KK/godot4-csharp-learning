---
import Layout from '../layouts/Layout.astro';
---

<Layout title="基础教程">
  <div class="mb-12">
    <h1 class="text-4xl font-bold mb-4 text-blue-400">📚 基础教程</h1>
    <p class="text-xl text-gray-300">
      从零开始，系统学习 Godot 4 C# 开发的基础知识
    </p>
  </div>

  <div class="space-y-8">
    <!-- Lesson 1 -->
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <div class="flex items-start gap-4">
        <div class="bg-blue-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold flex-shrink-0">1</div>
        <div class="flex-1">
          <h2 class="text-xl font-semibold mb-2 text-blue-400">
            <a href="/basics/lesson-01" class="hover:underline">Godot 4 编辑器入门</a>
          </h2>
          <p class="text-gray-400 mb-3">
            熟悉 Godot 4 的界面布局、项目面板、场景面板、检查器、文件系统。了解工作区切换和常用快捷键。
          </p>
          <div class="flex gap-4 text-sm text-gray-500">
            <span>⏱️ 30 分钟</span>
            <span>📝 实践：创建第一个项目</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Lesson 2 -->
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <div class="flex items-start gap-4">
        <div class="bg-blue-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold flex-shrink-0">2</div>
        <div class="flex-1">
          <h2 class="text-xl font-semibold mb-2 text-blue-400">
            <a href="/basics/lesson-02" class="hover:underline">C# 语言基础回顾</a>
          </h2>
          <p class="text-gray-400 mb-3">
            快速回顾 C# 核心概念：类、继承、接口、泛型、LINQ、异步编程。Godot C# 的特殊要求。
          </p>
          <div class="flex gap-4 text-sm text-gray-500">
            <span>⏱️ 45 分钟</span>
            <span>📝 实践：编写基础类</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Lesson 3 -->
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <div class="flex items-start gap-4">
        <div class="bg-blue-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold flex-shrink-0">3</div>
        <div class="flex-1">
          <h2 class="text-xl font-semibold mb-2 text-blue-400">
            <a href="/basics/lesson-03" class="hover:underline">节点与场景系统</a>
          </h2>
          <p class="text-gray-400 mb-3">
            深入理解 Godot 的核心：节点树、场景实例化、场景切换、节点生命周期（_Ready、_Process、_PhysicsProcess）。
          </p>
          <div class="flex gap-4 text-sm text-gray-500">
            <span>⏱️ 60 分钟</span>
            <span>📝 实践：创建场景层次结构</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Lesson 4 -->
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <div class="flex items-start gap-4">
        <div class="bg-blue-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold flex-shrink-0">4</div>
        <div class="flex-1">
          <h2 class="text-xl font-semibold mb-2 text-blue-400">
            <a href="/basics/lesson-04" class="hover:underline">Godot 内置类型</a>
          </h2>
          <p class="text-gray-400 mb-3">
            学习 Godot 特有的类型：Vector2、Vector3、Color、Rect2、Transform2D、Transform3D、Quaternion 等。
          </p>
          <div class="flex gap-4 text-sm text-gray-500">
            <span>⏱️ 45 分钟</span>
            <span>📝 实践：类型操作练习</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Lesson 5 -->
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <div class="flex items-start gap-4">
        <div class="bg-blue-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold flex-shrink-0">5</div>
        <div class="flex-1">
          <h2 class="text-xl font-semibold mb-2 text-blue-400">
            <a href="/basics/lesson-05" class="hover:underline">输入处理系统</a>
          </h2>
          <p class="text-gray-400 mb-3">
            配置输入映射、处理键盘鼠标输入、游戏手柄支持、触摸输入、Input 类的使用方法。
          </p>
          <div class="flex gap-4 text-sm text-gray-500">
            <span>⏱️ 40 分钟</span>
            <span>📝 实践：创建角色控制器</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Lesson 6 -->
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <div class="flex items-start gap-4">
        <div class="bg-blue-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold flex-shrink-0">6</div>
        <div class="flex-1">
          <h2 class="text-xl font-semibold mb-2 text-blue-400">
            <a href="/basics/lesson-06" class="hover:underline">2D 游戏开发基础</a>
          </h2>
          <p class="text-gray-400 mb-3">
            Sprite2D、TextureRect、Camera2D、TileMap、ParallaxBackground。创建简单的 2D 场景。
          </p>
          <div class="flex gap-4 text-sm text-gray-500">
            <span>⏱️ 60 分钟</span>
            <span>📝 实践：2D 角色移动</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-12 text-center">
    <a href="/advanced/" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-colors">
      完成基础后，进入进阶内容 →
    </a>
  </div>
</Layout>
